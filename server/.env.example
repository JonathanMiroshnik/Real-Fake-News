# Server Backend Environment Variables
# Copy this file to server/.env and adjust the values as needed
#
# This file is used for BOTH local development (npm run dev) and Docker.
# - Docker: docker-compose.yml loads it via env_file: server/.env
# - Local: server/src/index.ts loads it via dotenv.config()
#
# Variables set here override the defaults in docker-compose.yml's environment: block.
# To use a different location, copy/rename this file and adjust docker-compose.yml.

# =============================================================================
# REQUIRED — API Keys
# =============================================================================

# DeepSeek API Key (for LLM text generation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# NewsData.io API Key (for fetching real news)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Runware API Key (for image generation)
RUNWARE_API_KEY=your_runware_api_key_here

# =============================================================================
# SECURITY — Change Before Production
# =============================================================================

# Admin Password
# Used to access the admin panel. CHANGE THIS IN PRODUCTION!
ADMIN_PASSWORD=changeme123

# =============================================================================
# OPTIONAL — Override Docker Compose Defaults
# =============================================================================
# The following are already set in docker-compose.yml's environment: block.
# Uncomment them here only if you need different values for your setup.

# Node Environment
# NODE_ENV=development

# Client URL (for CORS headers)
# CLIENT_URL=http://localhost:5173

# Runware Image Model
# RUNWARE_IMAGE_MODEL=runware:z-image@turbo

# Enable Scheduled Jobs (article generation, news fetching)
# ENABLE_SCHEDULED_JOBS=false

# Enable Fake Data Fallback (auto-generated placeholder content)
# ENABLE_FAKE_DATA=false

# =============================================================================
# OPTIONAL — Database Location
# =============================================================================
# Only needed to override the default (../database/database.db at project root).
# In Docker, DATABASE_PATH is set in docker-compose.yml.
# DATABASE_PATH=../database/database.db

# =============================================================================
# OPTIONAL — Email (Currently Unused in Code)
# =============================================================================
# GMAIL_USER=your_gmail_address@gmail.com
# GMAIL_APP_PASSWORD=your_gmail_app_password_here

# =============================================================================
# OPTIONAL — Fake Image Configuration
# =============================================================================
# Controls the tiled-color placeholder images.
# FAKE_IMAGE_WIDTH=896
# FAKE_IMAGE_HEIGHT=512
# FAKE_IMAGE_TILES_X=8
# FAKE_IMAGE_TILES_Y=6
# FAKE_IMAGE_COLOR_MIN_R=30
# FAKE_IMAGE_COLOR_MAX_R=225
# FAKE_IMAGE_COLOR_MIN_G=30
# FAKE_IMAGE_COLOR_MAX_G=225
# FAKE_IMAGE_COLOR_MIN_B=30
# FAKE_IMAGE_COLOR_MAX_B=225

# =============================================================================
# NOTES
# =============================================================================
# - Place this file at: server/.env (it is gitignored)
# - docker-compose.yml loads it via env_file: server/.env
# - For local dev: it's loaded by dotenv in server/src/index.ts
# - docker-compose.yml's environment: block takes precedence over this file
