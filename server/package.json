{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend API server for Real-Fake-News — Express/TypeScript with SQLite",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "node --no-warnings dist/index.js",
    "prestart": "npm run build",
    "seed": "node data/seed-data.js",
    "migrate": "tsx src/scripts/migrateToSqlite.ts",
    "compress-images": "tsx src/scripts/compressExistingImages.ts",
    "generate-mock-data": "tsx src/scripts/generateMockData.ts",
    "generate-fake-image": "tsx src/scripts/generateFakeImage.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "news",
    "api",
    "express",
    "typescript",
    "sqlite"
  ],
  "author": "Real Fake News Team",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "dependencies": {
    "@runware/sdk-js": "^1.2.2",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "fs-extra": "^11.3.2",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jimp": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.11",
    "openai": "^4.93.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.1",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
