# Dependencies
node_modules/

# Environment files (never committed)
.env
admin/.env
server/.env
client/.env

# Build outputs
dist/
build/
server/dist/
client/dist/
admin/build/
*.log

# Database files (generated at runtime, mounted as Docker volume)
*.sqlite
*.sqlite-wal
*.sqlite-shm
# Default SQLITE_DATA_PATH mount directory (Docker volume)
/database/

# Server data images (stored inside database volume)
server/data/

# OS files
.DS_Store
Thumbs.db

# Test artifacts
coverage/
playwright-report/
test-results/
*.tsbuildinfo