{
  "name": "realfakenewsmern",
  "version": "1.0.0",
  "description": "**REAL FAKE NEWS**",
  "private": true,
  "scripts": {
    "format": "prettier --write . && cd client && npx eslint --fix . && cd ../server && npx eslint --fix .",
    "format:check": "prettier --check .",
    "test": "cd client && npm test && cd ../server && npm test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "lint": "cd client && npm run lint && cd ../server && npm run lint && cd ../admin && npm run lint",
    "typecheck": "cd client && npm run typecheck && cd ../server && npm run typecheck",
    "prepush": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vite": "^6.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ],
    "client/src/**/*.{ts,tsx,js,jsx}": [
      "client/node_modules/.bin/eslint --fix --no-warn-ignored --config client/eslint.config.js"
    ],
    "server/src/**/*.{ts,tsx,js,jsx}": [
      "server/node_modules/.bin/eslint --fix --no-warn-ignored --config server/eslint.config.js"
    ],
    "admin/src/**/*.{ts,tsx,js,jsx}": [
      "admin/node_modules/.bin/eslint --fix --no-warn-ignored --config admin/eslint.config.js"
    ]
  }
}
