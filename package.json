{
  "name": "realfakenewsmern",
  "version": "1.0.0",
  "description": "**REAL FAKE NEWS**",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:client && npm run test:server",
    "test:client": "cd client && npm test",
    "test:server": "cd server && npm test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "lint": "npm run lint:client && npm run lint:server && npm run lint:admin",
    "lint:client": "cd client && npm run lint",
    "lint:server": "cd server && npm run lint",
    "lint:admin": "cd admin && npm run lint",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "cd client && npm run typecheck",
    "typecheck:server": "cd server && npm run typecheck",
    "build": "npm run build:client && npm run build:server && npm run build:admin",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:admin": "cd admin && npm run build",
    "prepush": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vite": "^6.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ],
    "client/src/**/*.{ts,tsx,js,jsx}": [
      "client/node_modules/.bin/eslint --fix --no-warn-ignored --config client/eslint.config.js"
    ],
    "server/src/**/*.{ts,tsx,js,jsx}": [
      "server/node_modules/.bin/eslint --fix --no-warn-ignored --config server/eslint.config.js"
    ],
    "admin/src/**/*.{ts,tsx,js,jsx}": [
      "admin/node_modules/.bin/eslint --fix --no-warn-ignored --config admin/eslint.config.js"
    ]
  }
}
