#!/bin/sh
echo "🔍 Running pre-commit checks..."

# 1. Run lint-staged (format + eslint)
echo "📝 Running lint-staged (formatting & linting)..."
npx lint-staged
LINT_STAGED_EXIT=$?
if [ $LINT_STAGED_EXIT -ne 0 ]; then
  echo "❌ Lint-staged failed. Fix issues before committing."
  exit $LINT_STAGED_EXIT
fi

# 2. Check for secrets using Gitleaks
echo "🔐 Checking for secrets..."
GITLEAKS_PATH="/home/jonathan/.local/bin/gitleaks"
if [ -x "$GITLEAKS_PATH" ]; then
  $GITLEAKS_PATH detect --source=. --config=.gitleaks.toml --no-git --verbose
  GITLEAKS_EXIT=$?
  if [ $GITLEAKS_EXIT -ne 0 ]; then
    echo "❌ Secrets detected! Remove them before committing."
    exit $GITLEAKS_EXIT
  fi
  echo "✅ No secrets found."
else
  echo "⚠️  gitleaks not found at $GITLEAKS_PATH, skipping secrets check."
fi

# 3. File size check - reject files over 5MB
echo "📏 Checking file sizes..."
staged_files=$(git diff --cached --name-only)
has_large_files=false
while IFS= read -r file; do
  if [ -n "$file" ] && [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt 5242880 ]; then
      size_mb=$(echo "scale=2; $size / 1048576" | bc)
      echo "❌ $file is ${size_mb}MB (max 5MB)"
      has_large_files=true
    fi
  fi
done <<EOF
$staged_files
EOF

if [ "$has_large_files" = true ]; then
  echo "❌ Commit blocked: large files detected. Use Git LFS or remove them."
  exit 1
fi
echo "✅ All file sizes OK."

echo "✅ All pre-commit checks passed!"
