# Admin Panel Environment Variables
# Copy this file to .env and adjust the values as needed
#
# IMPORTANT: This file is ONLY for local development (npm run dev)
# For Docker, use the root .env file and docker-compose.yml build args

# =============================================================================
# API Configuration
# =============================================================================

# Use relative API URLs (for nginx proxy setup)
# When true, API calls use relative paths like "/api" instead of full URLs
VITE_USE_RELATIVE_API=false

# Backend Development Mode
# Set to "true" to use local development backend (localhost:5001)
# Set to "false" to use production backend
VITE_BACKEND_DEV_MODE=true

# API Base URLs (only used if VITE_USE_RELATIVE_API=false)
# Development mode server URL
VITE_API_BASE_DEV=http://localhost:5001
# Production mode server URL
VITE_API_BASE_PROD=https://real.sensorcensor.xyz

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend Development Mode
# Set to "true" for local development, "false" for production
VITE_FRONTEND_DEV_MODE=true

# Admin Panel Development Server Port
# Port for the Vite dev server (default: 5174)
VITE_PORT=5174

# =============================================================================
# Client URL Configuration (for article links)
# =============================================================================

# Development mode client URL - used when VITE_FRONTEND_DEV_MODE=true
VITE_CLIENT_URL_DEV=http://localhost:5173

# Production mode client URL - used when VITE_FRONTEND_DEV_MODE=false
VITE_CLIENT_URL_PROD=https://real.sensorcensor.xyz

# =============================================================================
# Notes
# =============================================================================
# - In Vite, environment variables must be prefixed with VITE_ to be accessible
# - These variables are baked into the bundle at BUILD time
# - For local development: Copy this file to .env and run "npm run dev"
# - For Docker: Use root .env file and docker-compose.yml build args
